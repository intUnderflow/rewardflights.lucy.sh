# Fonts are content-stable — cache them hard.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# The app shell (HTML/JS/CSS) has no content hashing, so it must revalidate on
# every load — otherwise a deploy stays hidden behind the browser cache. ETag
# 304s keep this cheap; a new deploy is picked up immediately.
/index.html
  Cache-Control: no-cache
/app.js
  Cache-Control: no-cache
/style.css
  Cache-Control: no-cache
/favicon.svg
  Cache-Control: no-cache
/sw.js
  Cache-Control: no-cache
/manifest.webmanifest
  Cache-Control: no-cache

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  X-Frame-Options: DENY
  Cache-Control: no-cache
  Content-Security-Policy: default-src 'none'; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data:; connect-src 'self' https://raw.githubusercontent.com https://api.github.com https://alerts-rewardflights.lucy.sh; worker-src 'self'; manifest-src 'self'; base-uri 'none'; form-action 'none'; frame-ancestors 'none'
